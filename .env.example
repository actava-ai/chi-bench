# Judge — always required.
# claude-opus-4-7 grades every trial regardless of which model is being
# benchmarked. Without this key, all runs fail at the verifier stage.
ANTHROPIC_API_KEY=

# Agent provider keys — provide whichever you need for your chosen rows.
OPENAI_API_KEY=             # Codex rows
GEMINI_API_KEY=             # Gemini CLI rows
OPENROUTER_API_KEY=         # OpenClaw / Hermes / OAI Agents / DeepAgents rows
# Claude Code agent harness uses CLAUDE_CODE_OAUTH_TOKEN by default. The OAuth
# token is a cheaper alternative for smoke-testing — set it only if you
# want Claude Code to authenticate via OAuth instead.
# CLAUDE_CODE_OAUTH_TOKEN=

# Hugging Face — required to download the gated chi-bench dataset
# via `chi-bench data download`. Authenticate with the CLI instead of
# storing a token here:
#   huggingface-cli login

# Optional (only when running on Modal). Authenticate with the Modal
# CLI; no token needs to be stored here:
#   modal setup
# Or, for a named profile:
#   modal token set --profile <name>
